<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F0F0F0">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/color_primary"
            android:padding="16dp"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/app_description"
                android:textColor="#BBDEFB"
                android:textSize="12sp"
                android:layout_marginTop="6dp" />

        </LinearLayout>

        <!-- Connection Parameters section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/white"
            android:padding="16dp"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/section_params"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/color_primary"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/label_target_ip"
                android:textSize="12sp"
                android:textColor="#757575" />

            <EditText
                android:id="@+id/etTargetIp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/hint_target_ip"
                android:inputType="textUri"
                android:singleLine="true"
                android:layout_marginBottom="12dp"
                android:text="192.168.1.100" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/label_target_port"
                android:textSize="12sp"
                android:textColor="#757575" />

            <EditText
                android:id="@+id/etTargetPort"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/hint_target_port"
                android:inputType="number"
                android:singleLine="true"
                android:layout_marginBottom="4dp"
                android:text="5288" />

        </LinearLayout>

        <!-- Optional Parameters section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/white"
            android:padding="16dp"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/section_optional"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/color_primary"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/label_service_network"
                android:textSize="12sp"
                android:textColor="#757575" />

            <EditText
                android:id="@+id/etServiceNetwork"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/hint_service_network"
                android:inputType="text"
                android:singleLine="true"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/label_bt_device"
                android:textSize="12sp"
                android:textColor="#757575" />

            <EditText
                android:id="@+id/etBtDevice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/hint_bt_device"
                android:inputType="text"
                android:singleLine="true"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/label_flags"
                android:textSize="12sp"
                android:textColor="#757575" />

            <EditText
                android:id="@+id/etFlags"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/hint_flags"
                android:inputType="text"
                android:singleLine="true"
                android:layout_marginBottom="4dp" />

        </LinearLayout>

        <!-- Actions section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/white"
            android:padding="16dp"
            android:layout_marginBottom="10dp">

            <!-- Server status indicator -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <View
                    android:id="@+id/statusDot"
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:background="@drawable/status_dot"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/tvServerStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/server_status_idle"
                    android:textSize="13sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- Start / Stop row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <Button
                    android:id="@+id/btnStartTest"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:text="@string/btn_start_test" />

                <Button
                    android:id="@+id/btnStopServer"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:text="@string/btn_stop_server"
                    android:enabled="false" />

            </LinearLayout>

            <!-- Log action row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnClearLogs"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:text="@string/btn_clear_logs" />

                <Button
                    android:id="@+id/btnSaveLogs"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:text="@string/btn_save_logs" />

            </LinearLayout>

        </LinearLayout>

        <!-- Log console section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/white"
            android:padding="12dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/section_log"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/color_primary"
                android:layout_marginBottom="8dp" />

            <ScrollView
                android:id="@+id/logScrollView"
                android:layout_width="match_parent"
                android:layout_height="300dp">

                <TextView
                    android:id="@+id/tvLog"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/log_background"
                    android:fontFamily="monospace"
                    android:padding="10dp"
                    android:text="@string/log_console_hint"
                    android:textColor="@color/log_text"
                    android:textSize="11sp" />

            </ScrollView>

        </LinearLayout>

    </LinearLayout>
</ScrollView>
